@model DabaTaseApp.Models.Instructor
@{
    ViewData["Title"] = "Редагувати інструктора";
}

<h1 class="mb-4">Редагування</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card-custom">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="form-group mb-4">
                    <label asp-for="FullName" class="form-label text-muted fw-bold">ПІБ Інструктора</label>
                    <input asp-for="FullName" class="form-control" placeholder="Наприклад: Шевченко Тарас Григорович" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                
                <div class="form-group mb-4">
                    <label asp-for="PhoneNumber" class="form-label text-muted fw-bold">Контактний телефон</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted fw-bold" id="basic-addon1">+</span>
                        <input asp-for="PhoneNumber" class="form-control" type="tel" placeholder="380XXXXXXXXX" aria-describedby="basic-addon1" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    <div class="form-text mt-1">Введіть номер у міжнародному форматі без пробілів.</div>
                </div>
                
                <div class="form-group mb-4">
                    <label asp-for="LicenseSerial" class="form-label text-muted fw-bold">Серія та номер ліцензії</label>
                    <input asp-for="LicenseSerial" class="form-control text-uppercase" placeholder="АВ 123456" />
                    <span asp-validation-for="LicenseSerial" class="text-danger small"></span>
                </div>
                
                <div class="form-group mt-5">
                    <button type="submit" class="btn btn-primary px-4 shadow-sm"><i class="bi bi-check-lg me-2"></i>Зберегти запис</button>
                    <a asp-action="Index" class="btn btn-link text-muted ms-3">Скасувати</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}