@model IEnumerable<DabaTaseApp.Models.Instructor>
@{
    ViewData["Title"] = "Інструктори";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="mb-0">Команда інструкторів</h1>
        <p class="text-muted mb-0">Керування викладацьким складом автошколи</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 py-2 shadow-sm" style="border-radius: 12px;">
        <i class="bi bi-plus-lg me-2"></i>Додати інструктора
    </a>
</div>

<div class="card-custom">
    <table class="table">
        <thead>
            <tr>
                <th>ПІБ Інструктора</th>
                <th>Номер телефону</th>
                <th>Серія ліцензії</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.FullName</td>
                    <td><i class="bi bi-telephone-fill text-muted me-2"></i>+@item.PhoneNumber?.Replace("+", "")</td>
                    <td><span class="badge bg-light text-primary border">@item.LicenseSerial</span></td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action" title="Редагувати">
                                <i class="bi bi-pencil-square text-primary"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-action" title="Деталі">
                                <i class="bi bi-info-circle text-info"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action" title="Видалити">
                                <i class="bi bi-trash3 text-danger"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>