@model DabaTaseApp.Models.Payment
@{
    ViewData["Title"] = "Деталі транзакції";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0 text-success">Чек №@Model.Id</h1>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary shadow-sm">
        <i class="bi bi-pencil me-2"></i>Редагувати
    </a>
</div>

<div class="card-custom mb-4" style="max-width: 600px;">
    <h5 class="fw-bold mb-4 text-muted border-bottom pb-2">Інформація про платіж</h5>
    <dl class="row mb-0">
        <dt class="col-sm-4 text-muted mb-3">Платник</dt>
        <dd class="col-sm-8 mb-3 fw-bold">@(Model.Student?.FullName ?? "Невідомо")</dd>

        <dt class="col-sm-4 text-muted mb-3">Дата та час</dt>
        <dd class="col-sm-8 mb-3">@Model.PaymentDate.ToString("dd.MM.yyyy HH:mm")</dd>

        <dt class="col-sm-4 text-muted">Зарахована сума</dt>
        <dd class="col-sm-8 fs-4 fw-bold text-success">+ @Model.Amount.ToString("N2") ₴</dd>
    </dl>
</div>

<div>
    <a asp-action="Index" class="btn btn-link text-muted">Назад</a>
</div>