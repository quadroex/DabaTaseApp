@model IEnumerable<DabaTaseApp.Models.Payment>
@{
    ViewData["Title"] = "Фінанси";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <p class="text-muted m-0">Історія надходжень та платежів учнів</p>
    <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg me-2"></i>Додати платіж</a>
</div>

<div class="card-custom">
    <table class="table">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Учень</th>
                <th>Сума</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="text-muted">@item.PaymentDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="fw-bold">@item.Student?.FullName</td>
                    <td><span class="badge bg-success-subtle text-success fs-6">+ @item.Amount.ToString("N2") ₴</span></td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-pencil-square text-primary"></i></a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-info-circle text-info"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-trash3 text-danger"></i></a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>