@model IEnumerable<DabaTaseApp.Models.PracticeSession>
@{
    ViewData["Title"] = "Практичні заняття";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Заняття з практики</h1>
        <p class="text-muted mb-0">Графік проведення занять</p>
    </div>
    <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg me-2"></i>Нове заняття</a>
</div>

<div class="card-custom">
    <table class="table">
        <thead>
            <tr>
                <th>Учень</th>
                <th>Автомобіль</th>
                <th>Дата та час проведення</th>
                <th>Статус</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var statusClass = item.Status switch
                {
                    "Заплановано" => "status-planned",
                    "Триває" => "status-ongoing",
                    "Завершено" => "status-done",
                    _ => "status-cancelled"
                };
                <tr>
                    <td>
                        <div class="fw-bold">@item.Student?.FullName</div>
                        <div class="small text-muted">Інструктор: @item.Instructor?.FullName</div>
                    </td>
                    <td><span class="badge bg-light text-dark border">@item.VehiclePlate</span></td>
                    <td>
                        <div class="fw-bold">@item.StartTime.ToString("dd.MM.yyyy")</div>
                        <div class="small text-muted">@item.StartTime.ToString("HH:mm") - @item.EndTime.ToString("HH:mm")</div>
                    </td>
                    <td><span class="status-badge @statusClass">@item.Status</span></td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-pencil-square text-primary"></i></a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-info-circle text-info"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-trash3 text-danger"></i></a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>