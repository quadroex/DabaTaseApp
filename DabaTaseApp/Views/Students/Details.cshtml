@model DabaTaseApp.Models.Student
@{
    ViewData["Title"] = "Картка учня";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0 text-primary">@Model.FullName</h1>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary shadow-sm">
        <i class="bi bi-pencil me-2"></i>Редагувати
    </a>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card-custom h-100">
            <h5 class="fw-bold mb-4 text-muted border-bottom pb-2">Загальна інформація</h5>
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted mb-3">Категорія</dt>
                <dd class="col-sm-8 mb-3"><span class="badge bg-light text-dark border fs-6 px-3 py-2">@Model.TargetCategory</span></dd>

                <dt class="col-sm-4 text-muted mb-3">Навчальна група</dt>
                <dd class="col-sm-8 mb-3 fw-bold text-primary">@(Model.Group?.GroupName ?? "Не призначено")</dd>

                <dt class="col-sm-4 text-muted">Поточний баланс</dt>
                <dd class="col-sm-8 fs-5 fw-bold text-@(Model.Balance < 0 ? "danger" : "success")">
                    @Model.Balance.ToString("N2") ₴
                </dd>
            </dl>
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-link text-muted">Назад</a>
</div>