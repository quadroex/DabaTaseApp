@model IEnumerable<DabaTaseApp.Models.Student>
@{
    ViewData["Title"] = "Учні";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Керування учнями</h1>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-lg me-2"></i>Додати учня
    </a>
</div>

<div class="card-custom">
    <table class="table">
        <thead>
            <tr>
                <th>ПІБ Учня</th>
                <th>Баланс</th>
                <th>Категорія</th>
                <th>Група</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.FullName</td>
                    <td>
                        <span class="text-@(item.Balance < 0 ? "danger" : "success") fw-bold">
                            @item.Balance.ToString("C")
                        </span>
                    </td>
                    <td><span class="badge bg-light text-dark border">@item.TargetCategory</span></td>
                    <td>@(item.Group?.GroupName ?? "Без групи")</td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-pencil-square text-primary"></i></a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-info-circle text-info"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action"><i class="bi bi-trash3 text-danger"></i></a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>