@model IEnumerable<DabaTaseApp.Models.Vehicle>
@{
    ViewData["Title"] = "Автопарк";
}

<div class="d-flex justify-content-between align-items-end mb-4">
    <div>
        <h1 class="mb-0">Навчальні авто</h1>
        <p class="text-muted mb-0">Моніторинг стану та доступності транспортних засобів</p>
    </div>
    <a asp-action="Create" class="btn btn-primary px-4 py-2 shadow-sm" style="border-radius: 12px;">
        <i class="bi bi-plus-lg me-2"></i>Додати автомобіль
    </a>
</div>

<div class="card-custom">
    <table class="table">
        <thead>
            <tr>
                <th>Номерний знак</th>
                <th>Марка та модель</th>
                <th>Статус</th>
                <th class="text-end">Дії</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold text-uppercase">@item.PlateNumber</td>
                    <td>@item.Mark @item.Model</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="status-badge bg-success-subtle text-success">
                                <i class="bi bi-check-circle-fill me-1"></i>Активний
                            </span>
                        }
                        else
                        {
                            <span class="status-badge bg-danger-subtle text-danger">
                                <i class="bi bi-x-circle-fill me-1"></i>В ремонті
                            </span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Edit" asp-route-id="@item.PlateNumber" class="btn-action">
                                <i class="bi bi-pencil-square text-primary"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.PlateNumber" class="btn-action">
                                <i class="bi bi-info-circle text-info"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.PlateNumber" class="btn-action">
                                <i class="bi bi-trash3 text-danger"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>