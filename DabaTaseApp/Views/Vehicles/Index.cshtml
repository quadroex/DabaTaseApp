@model IEnumerable<DabaTaseApp.Models.Vehicle>

@{
    
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="mb-0">Керування автопарком</h1>
            <p class="text-muted mb-0">Повний список транспортних засобів та їх статус</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Додати новий запис
        </a>
    </div>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PlateNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Mark)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Model)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsActive)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.PlateNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Mark)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Model)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsActive)
            </td>
                    <td class="text-end">
                        <div class="btn-group shadow-sm">
                            <a asp-action="Edit" asp-route-id="@item.PlateNumber" class="btn btn-light btn-sm" title="Редагувати">
                                <i class="bi bi-pencil text-primary"></i>
                            </a>
                            <a asp-action="Details" asp-route-id="@item.PlateNumber" class="btn btn-light btn-sm" title="Переглянути">
                                <i class="bi bi-eye text-info"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.PlateNumber" class="btn btn-light btn-sm" title="Видалити">
                                <i class="bi bi-trash text-danger"></i>
                            </a>
                        </div>
                    </td>
        </tr>
}
    </tbody>
</table>
</body>
</html>
